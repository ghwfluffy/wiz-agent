APP_ENV=development
APP_VERSION=0.1.0
AUTH_MODE=standalone
APP_BASE_PATH=
PUBLIC_URL=http://localhost:18081
BIND_ADDRESS=127.0.0.1
API_PORT=18080
WEB_PORT=18081
NGINX_PORT=18082
MCP_PORT=18083
QDRANT_PORT=6333

POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_dev_password
POSTGRES_DB=agent
POSTGRES_HOST=db
POSTGRES_PORT=5432

SESSION_COOKIE_NAME=agent_session
SESSION_COOKIE_PATH=/
SESSION_DURATION_MINUTES=1440

DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.test
DEV_USER_DISPLAY_NAME="Development User"
DEV_USER_IS_ADMIN=true

VITE_APP_BASE_PATH=
VITE_API_BASE_URL=/api/v1
VITE_AUTH_MODE=standalone

AGENT_OPENAI_MODEL_FAST=gpt-5-mini
AGENT_OPENAI_MODEL_SMART=gpt-5
AGENT_OPENAI_MODEL_ORCHESTRATOR=gpt-5
AGENT_OPENAI_MODEL_REPAIR=gpt-5-mini
AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_REPAIR_ATTEMPT_LIMIT=1
AGENT_MAX_TOOL_CALLS=10
AGENT_MAX_RUNTIME_SEC=120

AGENT_OWNER_EMAILS=dev@example.test
AGENT_OWNER_SMS_EMAILS=
AGENT_UNTRUSTED_REVIEW_SMS=
INBOUND_MAX_UNTRUSTED_PER_SENDER_PER_HOUR=3
INBOUND_MAX_UNTRUSTED_NOTIFICATIONS_PER_HOUR=10

GOALS_API_BASE_URL=http://goals-api:8000/api/v1
BUDGET_API_BASE_URL=http://fluffynomics-api:8000/api
QDRANT_URL=http://qdrant:6333
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_INDEX_BATCH_SIZE=10
MCP_SERVER_PORT=8010
